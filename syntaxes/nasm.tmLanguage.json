{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "NASM x86-64",
  "scopeName": "source.asm.nasm",
  "patterns": [
    { "include": "#strings" },
    { "include": "#comments" },
    { "include": "#labels" },
    { "include": "#directives" },
    { "include": "#registers" },
    { "include": "#instructions" },
    { "include": "#numbers" },
    { "include": "#punctuation" },
    { "include": "#symbols" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.asm.nasm",
          "match": ";.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.asm.nasm",
          "match": "\"(\\\\.|[^\"])*\""
        },
        {
          "name": "string.quoted.single.asm.nasm",
          "match": "'[^']*'"
        },
        {
          "name": "string.quoted.backtick.asm.nasm",
          "begin": "`",
          "end": "`",
          "patterns": [
            { "match": "\\\\." }
          ]
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.asm.nasm",
          "match": "[,]"
        },
        {
          "name": "punctuation.bracket.asm.nasm",
          "match": "[\\[\\]\\(\\)]"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.function.asm.nasm",
          "match": "^\\s*([a-zA-Z_?.%$#@~][a-zA-Z0-9_$#@~.?]*):"
        },
        {
          "name": "entity.name.function.local.asm.nasm",
          "match": "(\\.|%%|%\\$)[a-zA-Z_?][a-zA-Z0-9_$#@~.?]*"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.asm.nasm",
          "match": "(?i)\\b(SECTION|SEGMENT|ABSOLUTE|EXTERN|GLOBAL|COMMON|CPU|BITS|USE16|USE32|USE64|DEFAULT|STRICT|EQU|TIMES|ALIGN|STRUC|ENDSTRUC|ISTRUC|AT|IEND|INCBIN)\\b"
        },
        {
          "name": "keyword.operator.instruction.asm.nasm",
          "match": "(?i)\\b(DB|DW|DD|DQ|DT|DO|DY|DZ|RESB|RESW|RESD|RESQ|REST|RESO|RESY|RESZ|BYTE|WORD|DWORD|QWORD|TWORD|OWORD|YWORD|ZWORD|PTR|SHORT|NEAR|FAR|REL|ABS)\\b"
        },
        {
          "name": "keyword.operator.asm.nasm",
          "match": "%(?![a-zA-Z0-9_$#@~.?])"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "variable.language.register.asm.nasm",
          "match": "(?i)\\b(R([89]|1[0-5])[DBW]?|[ER]?[A-D]X|[ER]?[SD]I|[ER]?[BS]P|[A-D][LH]|[C-GS]S|[XYZ]MM([0-9]|[12][0-9]|3[01])|CR[0-9]|DR[0-9]|RIP|RFLAGS|EFLAGS|FLAGS|ST\\([0-7]\\)|MM[0-7]|TR[0-7]|GDTR|IDTR|LDTR|TR|MSW)\\b"
        }
      ]
    },
    "instructions": {
      "patterns": [
        {
          "name": "keyword.operator.instruction.asm.nasm",
          "match": "(?i)\\b(MOV|PUSH|POP|LEA|ADD|SUB|INC|DEC|NEG|MUL|IMUL|DIV|IDIV|AND|OR|XOR|NOT|SHL|SHR|SAL|SAR|ROL|ROR|RCL|RCR|CMP|TEST|JMP|CALL|RET|JE|JZ|JNE|JNZ|JG|JNLE|JGE|JNL|JL|JNGE|JLE|JNG|JA|JNBE|JAE|JNB|JB|JNAE|JBE|JNA|JS|JNS|JO|JNO|JP|JPE|JNP|JPO|JC|JNC|LOOP|LOOPE|LOOPZ|LOOPNE|LOOPNZ|MOVSS|MOVSD|MOVD|MOVQ|ADDSS|ADDSD|SUBSS|SUBSD|MULSS|MULSD|DIVSS|DIVSD|RCPSS|RSQRTSS|MINSS|MINSD|MAXSS|MAXSD|SQRTSS|SQRTSD|CMPEQSS|CMPLTSS|CMPLESS|CMPUNORDSS|CMPNESS|CMPNLTSS|CMPNLESS|CMPORDSS|ANDPS|ANDNPS|ORPS|XORPS|CMPPS|SHUFPS|UNPCKHPS|UNPCKLPS|CVTSI2SS|CVTSS2SI|CVTTSS2SI|CVTPS2PI|CVTTPS2PI|CVTPI2PS|CVTSD2SS|CVTSS2SD|CVTSI2SD|CVTSD2SI|CVTTSD2SI|CVTPD2PI|CVTTPD2PI|CVTPI2PD|PAUSE|LFENCE|MFENCE|SFENCE|CPUID|RDTSC|RDTSCP|IN|OUT|INT|IRET|IRETQ|SYSCALL|SYSRET|SYSENTER|SYSEXIT|HLT|NOP|WAIT|LOCK|REP|REPE|REPZ|REPNE|REPNZ|MOVZX|MOVSX|MOVSXD|SETCC|BT|BTC|BTR|BTS|BSF|BSR|BSWAP|XADD|CMPXCHG|CMPXCHG8B|CMPXCHG16B|FADD|FSUB|FMUL|FDIV|FLD|FST|FSTP|FCHS|FABS|FTST|FXAM|FLD1|FLDZ|FLDPI|FILD|FIST|FISTP|FCOM|FCOMP|FCOMPP|FUCOM|FUCOMP|FUCOMPP|FINIT|FWAIT|FNSAVE|FRSTOR|FNSTCW|FLDCW|FNSTSW|FCLEX|FNOP|F2XM1|FYL2X|FPTAN|FPATAN|FXCH|FPREM|FPREM1|FSIN|FCOS|FSINCOS|FPTAN|FSQRT|FYL2XP1|FRNDINT|FSCALE|FSTSW|FSTCW|FNSTENV|FLDENV|FSTENV|FNSAVE|FRSTOR|FWAIT|FNCLEX|FNINIT|FSETPM|FXSAVE|FXRSTOR|PREFETCH|VMOVAPS|VMOVUPS|VADDPS|VSUBPS|VMULPS|VDIVPS|VANDPS|VORPS|VXORPS)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.asm.nasm",
          "match": "(?i)\\b(0x[0-9a-fA-F]+|\\$[0-9a-fA-F]+|[0-9][0-9a-fA-F]*h)\\b"
        },
        {
          "name": "constant.numeric.binary.asm.nasm",
          "match": "(?i)\\b(0b[01]+|[01]+[by])\\b"
        },
        {
          "name": "constant.numeric.float.asm.nasm",
          "match": "(\\d+\\.\\d*|\\.\\d+)([eE][+-]?\\d+)?"
        },
        {
          "name": "constant.numeric.decimal.asm.nasm",
          "match": "\\b[0-9]+[dt]?\\b"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "variable.other.symbol.asm.nasm",
          "match": "(?:^|(?<=[^a-zA-Z0-9_$#@~.?]))([a-zA-Z_?%]|\\.|%%|%\\$|%\\?|%\\*|%#)[a-zA-Z0-9_$#@~.?]*(?=[^a-zA-Z0-9_$#@~.?]|$)"
        }
      ]
    }
  }
}
