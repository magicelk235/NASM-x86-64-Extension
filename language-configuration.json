{
    "comments": {
        "lineComment": ";"
    },
    "wordPattern": "(?:%%|%\\?|%\\*|%\\$|\\.[a-zA-Z_?]|[a-zA-Z_?%])[a-zA-Z0-9_$#@~.?]*|(?:0x[0-9a-fA-F]+|0b[01]+|\\d[0-9a-fA-F]*h?|\\d+)",
    "indentationRules": {
        "increaseIndentPattern": "^\\s*%(?:if\\w*|else|elif\\w*|i?r?macro|rep|while)\\b",
        "decreaseIndentPattern": "^\\s*%(?:endif|else|elif\\w*|endmacro|endrep|endwhile)\\b"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*[a-zA-Z_?][a-zA-Z0-9_$#@~.?]*:\\s*$",
            "action": { "indent": "indent" }
        }
    ],
    "brackets": [
        ["[", "]"],
        ["{", "}"],
        ["(", ")"]
    ],
    "colorizedBracketPairs": [
        ["[", "]"],
        ["{", "}"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        ["[", "]"],
        ["{", "}"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"],
        ["`", "`"]
    ],
    "surroundingPairs": [
        ["[", "]"],
        ["{", "}"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"],
        ["`", "`"]
    ]
}
